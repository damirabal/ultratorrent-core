// ---------------------------------------------------------------------------
// UPLM licensing — LOCAL STATE ONLY (Enterprise overlay).
//
// Product-key activation model (same as CCA): the external UPLM Licensing
// Manager signs an entitlement certificate; UltraTorrent activates a product
// key, verifies the signed certificate (fail-closed), stores it, re-validates
// monthly with a grace window, and gates premium/enterprise modules on the
// result. The verify/activate logic lives in packages/enterprise — Core ships
// these tables but never the licensing services.
// ---------------------------------------------------------------------------

/// Singleton license state (id fixed to "singleton"). Holds the verified
/// certificate, derived state, and the encrypted product key for re-validation.

/// The effective set of entitled module keys (from included_modules), rebuilt
/// on every activation/validation.

/// Audit trail of activation / validation / config transitions.

// ---------------------------------------------------------------------------
// Node Agent (Milestone 3) — every install carries a persistent identity and a
// local agent so it can later become centrally managed. Core writes identity,
// health, and local command/event records; the private Enterprise overlay adds
// the secure Central transport that fills NodeCentralConnection and drives
// remote commands. Core never executes proprietary remote workflows.
// ---------------------------------------------------------------------------

/// A soft-deleted file/folder moved into a storage root's `.ultratorrent-trash`.
/// Enables the Trash Browser, restore-to-original, and Empty Trash.
model TrashItem {
  id           String   @id @default(uuid())
  /// Original root-relative path before deletion (used to restore).
  originalPath String
  name         String
  /// Absolute path inside `.ultratorrent-trash/` where the item now lives.
  trashPath    String   @unique
  /// Absolute storage root the item belonged to (restore target base).
  storageRoot  String
  isDirectory  Boolean  @default(false)
  size         BigInt   @default(0)
  deletedById  String?
  deletedAt    DateTime @default(now())

  @@index([deletedAt])
  @@map("trash_items")
}

