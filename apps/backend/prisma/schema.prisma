model IMDbEpisode {
  id             String @id @default(uuid())
  episodeTitleId String @unique
  parentTitleId  String
  seasonNumber   Int?
  episodeNumber  Int?

  @@index([parentTitleId])
  @@index([parentTitleId, seasonNumber, episodeNumber])
  @@map("imdb_episodes")
}

model IMDbPrincipal {
  id         String  @id @default(uuid())
  titleId    String
  ordering   Int
  personId   String
  category   String?
  job        String?
  characters String?

  @@index([titleId])
  @@index([personId])
  @@map("imdb_principals")
}

model IMDbPerson {
  id                String   @id @default(uuid())
  nconst            String   @unique
  primaryName       String
  birthYear         Int?
  deathYear         Int?
  primaryProfession String[] @default([])
  knownForTitles    String[] @default([])

  @@index([primaryName])
  @@map("imdb_persons")
}

model IMDbRating {
  id            String @id @default(uuid())
  titleId       String @unique
  averageRating Float
  numVotes      Int

  @@index([averageRating])
  @@index([numVotes])
  @@map("imdb_ratings")
}

model IMDbDatasetImport {
  id              String    @id @default(uuid())
  status          String    @default("pending") // pending | validating | running | completed | failed | cancelled
  sourcePath      String
  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  errorMessage    String?
  filesImported   Json      @default("[]")
  recordsImported Int       @default(0)
  /// Optimized-import scan/skip counters (ImportStats): scanned, imported, skipped-by-*, errors, durationMs.
  stats           Json?
  /// Which import strategy produced this record (optimized_movies | full).
  strategy        String?
  datasetDate     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("imdb_dataset_imports")
}

// ---------------------------------------------------------------------------
// Notification Center — the centralized, provider-driven messaging platform.
// Cross-references use plain id columns + indexes (no hard FKs) to keep the
// domain self-contained. Secrets live encrypted inside `config` Json.
// ---------------------------------------------------------------------------

model NotificationChannel {
  id                String    @id @default(uuid())
  name              String
  description       String?
  provider          String // email | sms | telegram | whatsapp | discord | slack | webhook | ...
  enabled           Boolean   @default(true)
  isDefault         Boolean   @default(false)
  priority          Int       @default(0)
  /// Provider config incl. encrypted secrets (fields named in config.__encrypted). Redacted in API responses.
  config            Json      @default("{}")
  /// Capability snapshot from the provider (supportsImages, supportsButtons, …).
  capabilities      Json      @default("{}")
  rateLimitPerMin   Int?
  retryPolicy       Json      @default("{}") // { maxAttempts, backoffMs, backoffFactor }
  quietHours        Json      @default("{}") // { enabled, start, end, timezone }
  allowedEvents     Json      @default("[]") // event-name allowlist ([] = all)
  allowedGroupIds   Json      @default("[]")
  healthStatus      String    @default("unknown") // unknown | online | offline | degraded
  lastHealthCheckAt DateTime?
  lastError         String?
  sentCount         Int       @default(0)
  failedCount       Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([provider])
  @@index([enabled])
  @@map("notification_channels")
}

model NotificationRecipient {
  id                 String   @id @default(uuid())
  displayName        String
  email              String?
  phone              String?
  telegramChatId     String?
  whatsappNumber     String?
  language           String   @default("en-US")
  timezone           String?
  preferredChannelId String?
  enabled            Boolean  @default(true)
  quietHours         Json     @default("{}")
  /// Quick per-event opt toggles (fine-grained rows live in NotificationPreference).
  preferences        Json     @default("{}")
  /// Mapped UltraTorrent user (optional).
  userId             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([email])
  @@map("notification_recipients")
}

model NotificationRecipientGroup {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  /// Seeded groups (Administrators, Operators, …) that the UI marks as protected.
  system      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notification_recipient_groups")
}

model NotificationRecipientMember {
  id          String   @id @default(uuid())
  groupId     String
  recipientId String
  createdAt   DateTime @default(now())

  @@unique([groupId, recipientId])
  @@index([recipientId])
  @@map("notification_recipient_members")
}

model NotificationTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  /// Optional binding to a domain event.
  event       String?
  subject     String?
  title       String?
  subtitle    String?
  html        String?
  text        String?
  markdown    String?
  sms         String?
  whatsapp    String?
  telegram    String?
  /// Rich-card definition (badge/button/poster/backdrop variable bindings).
  card        Json     @default("{}")
  variables   Json     @default("[]")
  locale      String   @default("en-US")
  system      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([event])
  @@map("notification_templates")
}

model NotificationRule {
  id                 String    @id @default(uuid())
  name               String
  description        String?
  enabled            Boolean   @default(true)
  /// Trigger event name (from NOTIFICATION_EVENTS).
  event              String
  priority           Int       @default(0)
  severity           String    @default("info") // info | warning | critical
  /// [{ field, op, value }] evaluated against the event payload.
  conditions         Json      @default("[]")
  /// Recipient selection: { recipientIds:[], groupIds:[], mapEventUser:bool }.
  recipients         Json      @default("{}")
  /// Channel selection: channel ids ([] = each recipient's preferred/default).
  channelIds         Json      @default("[]")
  templateId         String?
  variables          Json      @default("{}")
  quietHoursOverride Boolean   @default(false)
  dedupeWindowSec    Int       @default(0)
  retryPolicy        Json      @default("{}")
  escalationPolicy   Json      @default("{}")
  rateLimitPerHour   Int?
  schedule           Json      @default("{}")
  tags               Json      @default("[]")
  system             Boolean   @default(false)
  triggerCount       Int       @default(0)
  lastTriggeredAt    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([event])
  @@index([enabled])
  @@map("notification_rules")
}

model NotificationDelivery {
  id                String    @id @default(uuid())
  ruleId            String?
  eventId           String?
  event             String
  channelId         String?
  provider          String
  recipientId       String?
  /// Resolved destination (email/phone/chat id). Redacted in list views by default.
  destination       String?
  templateId        String?
  subject           String?
  /// Rendered body snapshot for the chosen channel (omitted/redacted by default).
  renderedBody      String?
  card              Json      @default("{}")
  priority          Int       @default(0)
  severity          String    @default("info")
  status            String    @default("queued") // queued|sending|sent|delivered|failed|cancelled|skipped|retrying|throttled
  attempts          Int       @default(0)
  maxAttempts       Int       @default(3)
  dedupeKey         String?
  scheduledFor      DateTime?
  nextAttemptAt     DateTime?
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  error             String?
  providerMessageId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([channelId])
  @@index([recipientId])
  @@index([ruleId])
  @@index([event])
  @@index([priority])
  @@index([createdAt])
  @@index([dedupeKey])
  @@map("notification_deliveries")
}

model NotificationPreference {
  id          String   @id @default(uuid())
  recipientId String
  /// Event name or '*' (all events).
  event       String
  /// Provider/channel scope, or null = all channels.
  channel     String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([recipientId, event, channel])
  @@index([recipientId])
  @@map("notification_preferences")
}

model NotificationQueue {
  id           String    @id @default(uuid())
  deliveryId   String    @unique
  priority     Int       @default(0)
  scheduledFor DateTime  @default(now())
  leasedAt     DateTime?
  attempts     Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([scheduledFor])
  @@index([priority])
  @@map("notification_queue")
}

model NotificationAttachment {
  id          String   @id @default(uuid())
  deliveryId  String?
  templateId  String?
  filename    String
  contentType String?
  /// A URL or an artwork id reference; bytes fetched at send time.
  url         String?
  artworkId   String?
  cid         String?
  createdAt   DateTime @default(now())

  @@index([deliveryId])
  @@map("notification_attachments")
}

model NotificationEvent {
  id           String    @id @default(uuid())
  event        String
  payload      Json      @default("{}")
  dedupeKey    String?
  matchedRules Int       @default(0)
  processedAt  DateTime?
  createdAt    DateTime  @default(now())

  @@index([event])
  @@index([createdAt])
  @@index([dedupeKey])
  @@map("notification_events")
}

model NotificationStatistics {
  id        String   @id @default(uuid())
  /// Rollup bucket date (UTC midnight).
  date      DateTime
  provider  String?
  channelId String?
  event     String?
  sent      Int      @default(0)
  delivered Int      @default(0)
  failed    Int      @default(0)
  skipped   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, provider, channelId, event])
  @@index([date])
  @@map("notification_statistics")
}

// ---------------------------------------------------------------------------
// Subtitle Intelligence — the definitive subtitle acquisition, validation, and
// synchronization engine (core module `subtitle_intelligence`). It fingerprints
// every media file, searches providers with a progressively-relaxed strategy,
// scores + validates each candidate, installs the best as a media-server-correct
// sidecar (which media_manager's scanner then discovers), and NEVER overwrites an
// original. Provider secrets are AES-256-GCM encrypted at rest (SecretCipher).
// ---------------------------------------------------------------------------

model SubtitleProviderConfig {
  id             String    @id @default(uuid())
  provider       String    @unique // opensubtitles | subdl | local
  isEnabled      Boolean   @default(false)
  /// Higher = preferred. Feeds the "preferred provider" scoring bonus and the
  /// order providers are queried in.
  priority       Int       @default(0)
  /// Provider config incl. credentials. Secret keys are SecretCipher-encrypted at
  /// rest and redacted to `••••••••` in every API response.
  config         Json      @default("{}")
  /// Health snapshot from the last testConnection()/healthCheck().
  healthy        Boolean?
  lastCheckedAt  DateTime?
  lastError      String?
  /// Daily-quota bookkeeping — OpenSubtitles caps downloads/day; we surface what
  /// is left rather than discovering exhaustion mid-pipeline.
  quotaRemaining Int?
  quotaResetAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("subtitle_provider_configs")
}

/// The search IDENTITY of a media file. Reuses media_manager's mediainfo probe
/// (MediaFile) and external ids (MediaExternalId); adds only the hashes a
/// subtitle provider needs. One row per item (the primary video).
model SubtitleFingerprint {
  id            String   @id @default(uuid())
  itemId        String   @unique
  fileId        String? // the primary video MediaFile this fingerprint measures
  movieHash     String? // OpenSubtitles hash: first+last 64KB + filesize
  sha256        String?
  fileSize      BigInt   @default(0)
  runtimeSec    Int?
  frameRate     Float?
  resolution    String?
  videoCodec    String?
  audioCodec    String?
  audioLanguage String?
  container     String?
  source        String? // BluRay | WEB-DL | WEBRip | Remux | ...
  releaseGroup  String?
  hdr           String? // HDR10 | HDR10+ | DV | ...
  edition       String?
  season        Int?
  episode       Int?
  imdbId        String?
  tmdbId        String?
  tvdbId        String?
  mediaType     String? // movie | tv | anime
  computedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  item MediaItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([movieHash])
  @@index([imdbId])
  @@index([tmdbId])
  @@map("subtitle_fingerprints")
}

/// A normalized, scored search result. Providers normalize their raw payloads
/// into this shape; the scoring engine writes `score`/`scoreTier`/`scoreBreakdown`.
model SubtitleCandidate {
  id                String   @id @default(uuid())
  itemId            String
  provider          String
  providerFileId    String? // provider's own id, needed for the download step
  language          String
  releaseName       String?
  filename          String?
  movieHash         String?
  imdbId            String?
  tmdbId            String?
  tvdbId            String?
  season            Int?
  episode           Int?
  runtimeSec        Int?
  downloads         Int?
  uploader          String?
  rating            Float?
  trustedUploader   Boolean  @default(false)
  machineTranslated Boolean  @default(false)
  hearingImpaired   Boolean  @default(false)
  forced            Boolean  @default(false)
  fileSize          BigInt?
  downloadUrl       String?
  matchLevel        Int? // 1 hash | 2 release | 3 external-id | 4 title
  score             Int      @default(0) // normalized 0-100
  scoreTier         String? // auto | download | present | reject
  scoreBreakdown    Json?
  rawMetadata       Json?
  createdAt         DateTime @default(now())

  item MediaItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, language])
  @@index([provider])
  @@map("subtitle_candidates")
}

/// An installed subtitle — the authoritative acquisition record. `path` is the
/// sidecar written next to the video; the original is never overwritten.
model SubtitleDownload {
  id              String   @id @default(uuid())
  itemId          String
  provider        String
  language        String
  forced          Boolean  @default(false)
  hearingImpaired Boolean  @default(false)
  path            String
  releaseName     String?
  score           Int      @default(0)
  scoreTier       String?
  matchLevel      Int?
  fileSize        BigInt   @default(0)
  status          String   @default("installed") // installed | replaced | rejected | failed
  validationId    String?  @unique
  providerFileId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  item             MediaItem                 @relation(fields: [itemId], references: [id], onDelete: Cascade)
  validation       SubtitleValidation?       @relation(fields: [validationId], references: [id])
  synchronizations SubtitleSynchronization[]

  @@index([itemId])
  @@index([status])
  @@index([provider])
  @@index([language])
  @@map("subtitle_downloads")
}

/// The result of validating a subtitle before install. The structural checks are
/// pure (no binary); `runtimeDeltaSec`/`method` record the optional deep pass.
model SubtitleValidation {
  id              String   @id @default(uuid())
  format          String? // srt | ass | vtt | sub
  valid           Boolean  @default(false)
  cueCount        Int      @default(0)
  startMs         Int?
  endMs           Int?
  issues          Json     @default("[]")
  runtimeDeltaSec Int? // subtitle end vs measured media runtime (null when no probe)
  method          String? // pure | mediainfo | ffprobe
  createdAt       DateTime @default(now())

  download SubtitleDownload?

  @@map("subtitle_validations")
}

/// Per-library subtitle policy — which languages are required/preferred/forced,
/// the acceptance threshold, and provider preference order.
model SubtitleLanguageSetting {
  id                      String   @id @default(uuid())
  libraryId               String   @unique
  requiredLanguages       Json     @default("[]") // e.g. ["en","es"]
  preferredLanguages      Json     @default("[]")
  forcedLanguages         Json     @default("[]")
  hearingImpaired         Boolean  @default(false)
  machineTranslation      Boolean  @default(false)
  preferredProviders      Json     @default("[]") // provider keys, in order
  synchronizationRequired Boolean  @default(false)
  minimumScore            Int      @default(50)
  automaticReplacement    Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  library MediaLibrary @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  @@map("subtitle_language_settings")
}

/// An append-only trail of what the engine did, per item — the source for the
/// History UI and for "why is this the subtitle we installed?".
model SubtitleHistory {
  id        String   @id @default(uuid())
  itemId    String?
  action    String // searched | downloaded | validated | synchronized | replaced | rejected | failed | deleted
  provider  String?
  language  String?
  score     Int?
  message   String?
  metadata  Json?
  createdAt DateTime @default(now())

  item MediaItem? @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([action])
  @@index([createdAt])
  @@map("subtitle_history")
}

/// Long-running Subtitle Intelligence work, tracked as a row so progress can
/// stream over WebSocket and orphaned rows are failed out on restart (mirrors
/// MediaProcessingJob — in-process, no external broker).
model SubtitleJob {
  id         String    @id @default(uuid())
  type       String // missing_scan | search | download | validate | synchronize | provider_health | bulk_scan
  status     String    @default("queued") // queued | running | completed | failed
  libraryId  String?
  itemId     String?
  provider   String?
  language   String?
  payload    Json      @default("{}")
  result     Json?
  error      String?
  progress   Int       @default(0)
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status])
  @@index([type])
  @@index([libraryId])
  @@map("subtitle_jobs")
}

/// The result of synchronizing an installed subtitle to the audio. The original
/// is ALWAYS preserved (`originalPath`); the synced copy becomes the active
/// sidecar (`syncedPath`). Records offset/drift/confidence + the provider+version
/// that produced it, so a bad sync can be explained and reverted.
model SubtitleSynchronization {
  id             String   @id @default(uuid())
  downloadId     String
  provider       String // ffsubsync | manual_offset | alass
  method         String // audio | offset
  version        String?
  offsetMs       Int      @default(0)
  driftFactor    Float    @default(1)
  confidence     Float? // 0..1, when the provider reports one
  matchedRegions Json? // matched speech-region summary, when available
  originalPath   String
  syncedPath     String
  status         String   @default("applied") // applied | skipped | failed
  message        String?
  createdAt      DateTime @default(now())

  download SubtitleDownload @relation(fields: [downloadId], references: [id], onDelete: Cascade)

  @@index([downloadId])
  @@map("subtitle_synchronizations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Unified Jobs Center — the platform-wide normalized job model. A superset over
// the legacy per-module job tables (media_processing_jobs, subtitle_jobs, …),
// which remain during incremental migration. Status is a String enforced by the
// server-side state machine in code (matching the schema's String convention).
// See docs/UNIFIED_JOBS_CENTER_ARCHITECTURE_REVIEW.md.
// ─────────────────────────────────────────────────────────────────────────────

model PlatformJob {
  id            String  @id @default(uuid())
  // Identity
  type          String // registered JobDefinition type, e.g. "media.library_scan"
  name          String?
  description   String?
  moduleKey     String // owning module (media_manager, subtitle_intelligence, …)
  workspaceKey  String? // owning workspace (media, downloads, system, …)
  sourceType    String  @default("manual") // manual | scheduled | event | automation | workflow | system
  sourceId      String?
  correlationId String?
  parentJobId   String?
  rootJobId     String?

  // Related execution (nullable — populated when applicable)
  scheduleId          String?
  workflowExecutionId String?

  // Related resource
  resourceType String?
  resourceId   String?
  libraryId    String?
  mediaItemId  String?

  // Lifecycle
  status              String    @default("queued") // see JobStatus state machine
  phase               String?
  progressPercent     Int       @default(0)
  progressCurrent     Int?
  progressTotal       Int?
  progressUnit        String?
  statusMessageKey    String?
  statusMessageParams Json?
  queuedAt            DateTime  @default(now())
  scheduledFor        DateTime?
  startedAt           DateTime?
  heartbeatAt         DateTime?
  completedAt         DateTime?
  failedAt            DateTime?
  cancelledAt         DateTime?
  pausedAt            DateTime?
  resumedAt           DateTime?
  expiresAt           DateTime?

  // Execution controls
  priority          Int       @default(0)
  queueName         String?
  workerId          String?
  attempt           Int       @default(1)
  maxAttempts       Int       @default(1)
  retryPolicy       Json?
  retryAt           DateTime?
  timeoutSeconds    Int?
  cancellable       Boolean   @default(false)
  pausable          Boolean   @default(false)
  resumable         Boolean   @default(false)
  retryable         Boolean   @default(false)
  idempotencyKey    String?
  checkpointVersion Int?
  checkpoint        Json?

  // Ownership & security
  createdById        String?
  runAsUserId        String?
  requiredPermission String?
  visibilityScope    String  @default("module") // module | own | public

  // Inputs & outputs (summarized/sanitized only — never raw secrets/logs/binaries)
  // `inputData` is the re-execution input (IDs/paths; job inputs must not carry raw
  // secrets — handlers resolve secrets from config at run time). Enables retry-after-
  // restart, rerun, and resume. `inputSummary` is the redacted display form.
  inputData     Json?
  inputSummary  Json?
  resultSummary Json?
  errorCode     String?
  errorMessage  String?
  warnings      Json?
  metrics       Json?
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   PlatformJob?       @relation("JobHierarchy", fields: [parentJobId], references: [id], onDelete: SetNull)
  children PlatformJob[]      @relation("JobHierarchy")
  events   PlatformJobEvent[]

  @@index([status, createdAt])
  @@index([status, priority, queuedAt])
  @@index([workspaceKey, status])
  @@index([moduleKey, status])
  @@index([type, status])
  @@index([createdById, createdAt])
  @@index([parentJobId])
  @@index([rootJobId])
  @@index([correlationId])
  @@index([workerId, status])
  @@index([scheduledFor, status])
  @@index([heartbeatAt, status])
  @@index([scheduleId])
  @@index([idempotencyKey])
  @@map("platform_jobs")
}

model PlatformJobEvent {
  id               String   @id @default(uuid())
  jobId            String
  sequence         Int // monotonic per job
  level            String   @default("info") // debug | info | warning | error | success
  eventType        String // created | queued | started | progress | phase_changed | warning | retry_scheduled | pausing | paused | resumed | cancelling | cancelled | failed | completed | child_created | dependency_wait | stalled | heartbeat | output_available
  messageKey       String?
  messageParams    Json?
  sanitizedMessage String?
  progress         Int?
  metadata         Json?
  createdAt        DateTime @default(now())

  job PlatformJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, sequence])
  @@index([jobId, createdAt])
  @@index([level])
  @@index([eventType])
  @@map("platform_job_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Visual Workflow Builder — a durable, versioned graph automation platform that
// EXTENDS the Automation Engine (which stays as the simple-rule engine). Statuses
// are Strings enforced by server-side state machines (matching the codebase
// convention). Execution state is relational + queryable; the visual graph lives in
// WorkflowVersion.graph (JSON), never the execution history. See
// docs/WORKFLOW_BUILDER_ARCHITECTURE_REVIEW.md.
// ─────────────────────────────────────────────────────────────────────────────

model Workflow {
  id                    String    @id @default(uuid())
  name                  String
  description           String?
  workspaceKey          String?
  enabled               Boolean   @default(false)
  status                String    @default("draft") // draft | validation_failed | ready | published | disabled | archived
  tags                  String[]  @default([])
  // Denormalized pointers (no FK — avoids a circular relation with WorkflowVersion).
  currentDraftVersionId String?
  publishedVersionId    String?
  createdById           String?
  updatedById           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  archivedAt            DateTime?

  versions   WorkflowVersion[]
  executions WorkflowExecution[]

  @@index([status])
  @@index([enabled])
  @@index([workspaceKey])
  @@index([updatedAt])
  @@map("workflows")
}

model WorkflowVersion {
  id                  String    @id @default(uuid())
  workflowId          String
  versionNumber       Int
  status              String    @default("draft") // draft | validation_failed | ready | published | archived
  graph               Json // the immutable-once-published workflow graph (nodes/edges/metadata)
  triggerSummary      Json?
  requiredPermissions String[]  @default([])
  checksum            String
  changeNotes         String?
  createdById         String?
  createdAt           DateTime  @default(now())
  publishedAt         DateTime?
  archivedAt          DateTime?

  workflow   Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  executions WorkflowExecution[]

  @@unique([workflowId, versionNumber])
  @@index([workflowId])
  @@index([status])
  @@map("workflow_versions")
}

model WorkflowExecution {
  id                      String    @id @default(uuid())
  workflowId              String
  workflowVersionId       String
  triggerType             String?
  triggerEventId          String?
  triggerSource           String?   @default("event") // event | manual | scheduled | subworkflow | webhook
  correlationId           String?
  traceId                 String?
  status                  String    @default("queued") // see WorkflowExecutionStatus state machine
  inputContext            Json?
  outputSummary           Json?
  currentNodeIds          String[]  @default([])
  // Link to the Unified Jobs Center parent job for this execution.
  jobId                   String?
  // The identity actions run as (least-privilege; explicit for scheduled).
  executionIdentityUserId String?
  // Durable resume points (restart-safe): a delay's due time, a wait/approval expiry.
  resumeAt                DateTime?
  expiresAt               DateTime?
  heartbeatAt             DateTime?
  parentExecutionId       String? // for subworkflows
  depth                   Int       @default(0)
  startedAt               DateTime?
  completedAt             DateTime?
  failedAt                DateTime?
  cancelledAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  workflow  Workflow                @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version   WorkflowVersion         @relation(fields: [workflowVersionId], references: [id])
  nodes     WorkflowNodeExecution[]
  approvals WorkflowApproval[]

  @@index([status, createdAt])
  @@index([workflowId, createdAt])
  @@index([workflowVersionId])
  @@index([correlationId])
  @@index([status, resumeAt])
  @@index([status, expiresAt])
  @@index([heartbeatAt, status])
  @@index([parentExecutionId])
  @@map("workflow_executions")
}

model WorkflowNodeExecution {
  id                  String    @id @default(uuid())
  workflowExecutionId String
  nodeId              String
  nodeType            String
  status              String    @default("pending") // see WorkflowNodeStatus state machine
  attempt             Int       @default(1)
  maxAttempts         Int       @default(1)
  inputSummary        Json?
  outputSummary       Json?
  jobId               String? // linked Jobs Center child job for a long-running action node
  errorCode           String?
  errorMessage        String?
  warnings            Json?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  execution WorkflowExecution @relation(fields: [workflowExecutionId], references: [id], onDelete: Cascade)

  @@index([workflowExecutionId, nodeId])
  @@index([status])
  @@index([jobId])
  @@map("workflow_node_executions")
}

model WorkflowApproval {
  id                  String    @id @default(uuid())
  workflowExecutionId String
  nodeExecutionId     String?
  status              String    @default("pending") // pending | approved | rejected | expired | cancelled
  requestedFromUserId String?
  requestedFromRoleId String?
  requiredPermission  String?
  riskLevel           String?   @default("normal") // normal | elevated | destructive
  requestedAt         DateTime  @default(now())
  respondedAt         DateTime?
  respondedById       String?
  comment             String?
  expiresAt           DateTime?

  execution WorkflowExecution @relation(fields: [workflowExecutionId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@index([workflowExecutionId])
  @@map("workflow_approvals")
}

model WorkflowVariable {
  id             String   @id @default(uuid())
  scope          String   @default("workflow") // global | workflow
  workflowId     String?
  key            String
  valueType      String   @default("string") // string | number | boolean | json | secret
  encryptedValue String? // set for valueType=secret (SecretCipher)
  plainValue     Json? // set for non-secret values
  description    String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([scope, workflowId, key])
  @@index([scope])
  @@map("workflow_variables")
}

model WorkflowTemplate {
  id                  String   @id @default(uuid())
  key                 String   @unique
  nameKey             String
  descriptionKey      String?
  category            String   @default("general")
  graph               Json
  requiredModules     String[] @default([])
  requiredPermissions String[] @default([])
  defaultEnabled      Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([category])
  @@map("workflow_templates")
}
