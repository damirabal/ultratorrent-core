  status       String   @default("planned") // planned | done | failed | skipped | rolled_back
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  job MediaRenameJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("media_rename_files")
}

model MediaNamingTemplate {
  id           String   @id @default(uuid())
  name         String
  mediaType    String // tv | anime | movie | music | audiobook | general
  serverPreset String // plex | jellyfin | emby | kodi | custom
  template     String
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("media_naming_templates")
}

model MediaServerConfig {
  id              String   @id @default(uuid())
  provider        String // plex | jellyfin | emby | kodi
  name            String
  baseUrl         String
  // SecretCipher ciphertext of the server config (API token etc); never raw.
  encryptedConfig String
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([provider])
  @@map("media_server_configs")
}

// ---------------------------------------------------------------------------
// Enterprise release modules (Milestone 7) — written only by the white-label /
// central-backups / central-updates overlays. Core ships the tables.
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Media Acquisition Intelligence (Premium overlay) — decides what to acquire.
// Written only by the private media-acquisition overlay. Never performs file
// operations; it records explainable decisions + recommendations.
// ---------------------------------------------------------------------------

model MediaAcquisitionWatchlistItem {
  id              String   @id @default(uuid())
  type            String // series | season | episode | movie | movie_collection | anime | manual_query
  title           String
  normalizedTitle String
  // Alternate show titles releases are published under, when they differ from
  // `title`. Show identity is matched token-for-token against the release's title
  // region, so a release that renames the show is otherwise unreachable: Riverdale
  // ships as "Riverdale US", The Bad Batch as "Star Wars The Bad Batch". Each alias
  // is matched with the same rule as `title` — an alias widens WHICH titles count as
  // this show, it never loosens the comparison itself, so "Rise" still cannot pull in
  // "The Pendragon Cycle Rise of the Merlin".
  titleAliases    String[] @default([])
  year            Int?
  externalIds     Json?
  seasonNumber    Int?
  episodeNumber   Int?
  collectionName  String?
  status          String   @default("active") // active | paused | completed | archived
  priority        Int      @default(100)
  profileId       String?
  // Optional link to an RSS rule whose match preferences drive auto-download for
  // this show. Null → fall back to the global AcquisitionMatchCandidate defaults.
  rssRuleId       String?
  targetLibraryId String?
  // The library show this item monitors — the folder its episodes are filed into.
  // Bound once, when the show is picked from the library, so the download path is a
  // path the library OBSERVED rather than one reconstructed from `title` at grab
  // time. Null only for a show that is not in the library yet (or a movie); then,
  // and only then, does the sweep fall back to resolving a folder by name.
  libraryShowId   String?
  settings        Json?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  libraryShow MediaShow? @relation(fields: [libraryShowId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([normalizedTitle])
  @@index([libraryShowId])
  @@map("media_acquisition_watchlist_items")
}

/// Computed missing/owned-episode diff for a monitored series (a `series`/`season`
/// watchlist item). One row per catalogued episode; the scan upserts these and the
/// UI reads them. Loosely coupled to the watchlist item by id (no FK), matching the
/// module's convention (cf. `profileId`).
model WantedEpisode {
  id                  String    @id @default(uuid())
  watchlistItemId     String
  seriesTconst        String
  episodeTconst       String?
  seasonNumber        Int
  episodeNumber       Int
  episodeTitle        String?
  airYear             Int?
  status              String    @default("missing") /// missing | unaired | owned | ignored
  // Auto-acquire bridge state (preserved across rescans for still-missing rows).
  searchStatus        String    @default("idle") /// idle | searching | grabbed | pending_approval | no_results | failed
  lastSearchedAt      DateTime?
  grabbedAt           DateTime?
  grabbedEvaluationId String?
  downloadUrl         String?
  releaseTitle        String?
  lastCheckedAt       DateTime  @default(now())
  createdAt           DateTime  @default(now())

  @@unique([watchlistItemId, seasonNumber, episodeNumber])
  @@index([watchlistItemId])
  @@index([seriesTconst])
  @@index([status])
  @@map("wanted_episodes")
}

/// Computed missing/owned status for a monitored movie (a `movie` watchlist item
/// carrying an IMDb id). One row per movie watchlist item; the scan upserts it.
model WantedMovie {
  id                  String    @id @default(uuid())
  watchlistItemId     String    @unique
  movieTconst         String
  title               String
  year                Int?
  status              String    @default("missing") /// missing | unaired | owned | ignored
  // Auto-acquire bridge state (mirrors WantedEpisode; reserved for movie auto-search).
  searchStatus        String    @default("idle") /// idle | searching | grabbed | pending_approval | no_results | failed
  lastSearchedAt      DateTime?
  grabbedAt           DateTime?
  grabbedEvaluationId String?
  downloadUrl         String?
  releaseTitle        String?
  lastCheckedAt       DateTime  @default(now())
  createdAt           DateTime  @default(now())

  @@index([movieTconst])
  @@index([status])
  @@map("wanted_movies")
}

/// A Torznab/Newznab indexer the acquisition bridge searches for releases. The
/// API key is AES-256-GCM encrypted inside `config` (SecretCipher) and never
/// returned by the API. `capabilities` caches the last `t=caps` negotiation.
model Indexer {
  id             String    @id @default(uuid())
  name           String
  implementation String    @default("torznab") /// torznab | newznab
  protocol       String    @default("torrent") /// torrent | usenet
  baseUrl        String
  config         Json      @default("{}") /// { apiKey: <ciphertext>, __encrypted: ["apiKey"] }
  enabled        Boolean   @default(true)
  priority       Int       @default(25)
  categories     Int[]     @default([5000, 5030, 5040])
  capabilities   Json?
  minSeeders     Int?
  timeoutMs      Int       @default(15000)
  status         String    @default("unknown") /// ok | error | unknown
  statusMessage  String?
  lastTestedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([enabled])
  @@map("indexers")
}

model MediaAcquisitionProfile {
  id                  String   @id @default(uuid())
  name                String
  description         String?
  mediaType           String // tv | movie | anime | any
  minimumScore        Int      @default(0)
  approvalScore       Int      @default(0)
  minimumResolution   String?
  preferredResolution String?
  preferredSource     String?
  preferredCodec      String?
  preferredAudio      String?
  preferredHdr        String?
  preferredLanguages  Json?
  requiredTerms       Json?
  excludedTerms       Json?
  preferredGroups     Json?
  // Release size bounds in bytes. BigInt, not Int: a 1080p movie exceeds the
  // Int32 ceiling (2.1 GB). Null on either side = unbounded there. These become
  // the `sizeRules` of the preference tier this profile is turned into, so a
  // profile can cap release size the way a match candidate can.
  minSizeBytes        BigInt?
  maxSizeBytes        BigInt?
  qualityRules        Json?
  duplicateRules      Json?
  storageRules        Json?
  automationRules     Json?
  enabled             Boolean  @default(true)
  createdBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("media_acquisition_profiles")
}

/// Global default auto-download match preferences — an ordered candidate list
/// (lower priorityOrder = higher preference) reusing the RSS match-engine model
/// (`qualityRules` + `sizeRules` + required/excluded terms). Used by the
/// missing-episode auto-acquire bridge to decide which release to grab, so
/// preferences (incl. a real size cap) are configured the same way as RSS rules.
/// When a monitored show is linked to an RSS rule, that rule's candidates are
/// used instead; this is the fallback for shows without one.
model AcquisitionMatchCandidate {
  id            String    @id @default(uuid())
  priorityOrder Int       @default(0)
  name          String
  description   String?
  enabled       Boolean   @default(true)
  matchType     String    @default("smart_episode_match") // exact_text | contains_text | regex | wildcard | smart_episode_match | smart_movie_match | fuzzy_match
  pattern       String?
  requiredTerms Json      @default("[]")
  excludedTerms Json      @default("[]")
  qualityRules  Json      @default("{}") // { quality, source, codec, resolution, season, episode, year }
  sizeRules     Json      @default("{}") // { minBytes, maxBytes }
  lastMatchedAt DateTime?
  matchCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("acquisition_match_candidates")
}

model MediaAcquisitionEvaluation {
  id               String   @id @default(uuid())
  sourceType       String // rss | manual | watchlist_sweep | upgrade_sweep | automation
  sourceId         String?
  releaseName      String
  parsedMetadata   Json?
  watchlistItemId  String?
  profileId        String?
  libraryMatch     Json?
  releaseScore     Json?
  duplicateRisk    Json?
  qualityGap       Json?
  storageCheck     Json?
  serverSelection  Json?
  decision         String // download | skip | hold_for_approval | upgrade_existing | replace_existing | manual_review
  decisionReason   String?
  priority         Int      @default(100)
  confidence       Int      @default(0)
  requiresApproval Boolean  @default(false)
  approvalStatus   String   @default("not_required") // not_required | pending | approved | rejected | expired
  actionTaken      String?
  torrentHash      String?
  trace            Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  actions MediaAcquisitionAction[]

  @@index([decision])
  @@index([approvalStatus])
  @@index([createdAt])
  @@map("media_acquisition_evaluations")
}

model MediaAcquisitionAction {
  id           String    @id @default(uuid())
  evaluationId String
  actionType   String // download_torrent | assign_category | apply_tags | set_save_path | rename_after_download | scan_library_after_import | notify_user
  status       String    @default("pending") // pending | running | completed | failed
  payload      Json?
  result       Json?
  createdBy    String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  errorMessage String?

  evaluation MediaAcquisitionEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@map("media_acquisition_actions")
}

model MediaAcquisitionHistory {
  id              String   @id @default(uuid())
  watchlistItemId String?
  evaluationId    String?
  eventType       String
  message         String
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([watchlistItemId])
  @@index([createdAt])
  @@map("media_acquisition_history")
}

// ---------------------------------------------------------------------------
// IMDb metadata provider — a local, queryable mirror of the official IMDb
// non-commercial TSV datasets (imported from user-supplied .tsv.gz files) plus
// bookkeeping for dataset imports. NO data is scraped from imdb.com web pages;
// these tables are populated only from the licensed datasets (or, at runtime,
// an optional configured official/licensed IMDb REST API).
// ---------------------------------------------------------------------------

model IMDbTitle {
  id             String   @id @default(uuid())
  tconst         String   @unique
  titleType      String
  primaryTitle   String
  originalTitle  String
  isAdult        Boolean  @default(false)
  startYear      Int?
  endYear        Int?
  runtimeMinutes Int?
  genres         String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([primaryTitle])
  @@index([originalTitle])
  @@index([startYear])
  @@index([titleType])
  // Optimized movie import filters/sorts on (titleType, year) together.
  @@index([titleType, startYear])
  @@index([isAdult])
  // Genre filtering over the String[] column — GIN for array containment.
  @@index([genres], type: Gin)
  @@map("imdb_titles")
}

model IMDbAka {
  id              String  @id @default(uuid())
  titleId         String // references IMDbTitle.tconst (stored as the tconst string)
  title           String
  region          String?
  language        String?
  types           String?
  attributes      String?
  ordering        Int?
  isOriginalTitle Boolean @default(false)

  // (titleId, ordering) is IMDb's natural key for an alternate title, so a
  // re-import upserts rather than duplicating — makes the import idempotent.
  @@unique([titleId, ordering])
  @@index([titleId])
  // Release-name matching searches alternate titles by text.
  @@index([title])
  @@map("imdb_akas")
}

model IMDbCrew {
  id        String   @id @default(uuid())
  titleId   String   @unique
  directors String[] @default([])
  writers   String[] @default([])

