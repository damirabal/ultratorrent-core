// ---------------------------------------------------------------------------
// IMDb metadata provider — a local, queryable mirror of the official IMDb
// non-commercial TSV datasets (imported from user-supplied .tsv.gz files) plus
// bookkeeping for dataset imports. NO data is scraped from imdb.com web pages;
// these tables are populated only from the licensed datasets (or, at runtime,
// an optional configured official/licensed IMDb REST API).
// ---------------------------------------------------------------------------

model IMDbTitle {
  id             String   @id @default(uuid())
  tconst         String   @unique
  titleType      String
  primaryTitle   String
  originalTitle  String
  isAdult        Boolean  @default(false)
  startYear      Int?
  endYear        Int?
  runtimeMinutes Int?
  genres         String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([primaryTitle])
  @@index([originalTitle])
  @@index([startYear])
  @@index([titleType])
  // Optimized movie import filters/sorts on (titleType, year) together.
  @@index([titleType, startYear])
  @@index([isAdult])
  // Genre filtering over the String[] column — GIN for array containment.
  @@index([genres], type: Gin)
  @@map("imdb_titles")
}

model IMDbAka {
  id              String  @id @default(uuid())
  titleId         String // references IMDbTitle.tconst (stored as the tconst string)
  title           String
  region          String?
  language        String?
  types           String?
  attributes      String?
  ordering        Int?
  isOriginalTitle Boolean @default(false)

  // (titleId, ordering) is IMDb's natural key for an alternate title, so a
  // re-import upserts rather than duplicating — makes the import idempotent.
  @@unique([titleId, ordering])
  @@index([titleId])
  // Release-name matching searches alternate titles by text.
  @@index([title])
  @@map("imdb_akas")
}

