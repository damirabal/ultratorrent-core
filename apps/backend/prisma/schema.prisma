// UltraTorrent data model.
// Generated client is consumed by the Infrastructure layer only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & access control
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  displayName  String?
  passwordHash String
  isActive     Boolean  @default(true)
  isSystem     Boolean  @default(false)
  lastLoginAt  DateTime?
  // Two-factor authentication (TOTP). Secret is encrypted at rest.
  totpSecret    String?
  totpEnabled   Boolean  @default(false)
  recoveryCodes String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles         UserRole[]
  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  family     String
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ApiKey {
  id         String   @id @default(uuid())
  userId     String
  name       String
  prefix     String   @unique
  keyHash    String
  scopes     String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

// ---------------------------------------------------------------------------
// Torrent engines & snapshots
// ---------------------------------------------------------------------------

model TorrentEngine {
  id        String   @id @default(uuid())
  name      String
  kind      String   // rtorrent | qbittorrent | transmission | deluge
  config    Json     // connection details (encrypted secrets at rest)
  isDefault Boolean  @default(false)
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots TorrentSnapshot[]
  parked    ParkedTorrent[]

  @@map("torrent_engines")
}

model TorrentSnapshot {
  id           String   @id @default(uuid())
  engineId     String
  hash         String
  name         String
  state        String
  progress     Float
  size         BigInt
  downloaded   BigInt
  uploaded     BigInt
  ratio        Float
  downloadRate Int
  uploadRate   Int
  savePath     String
  label        String?
  categoryId   String?
  addedAt      DateTime?
  completedAt  DateTime?
  capturedAt   DateTime @default(now())

  engine   TorrentEngine     @relation(fields: [engineId], references: [id], onDelete: Cascade)
  category TorrentCategory?  @relation(fields: [categoryId], references: [id])
  tags     TorrentTagLink[]

  @@unique([engineId, hash])
  @@index([state])
  @@index([categoryId])
  @@map("torrent_snapshots")
}

/// A torrent held OUT of the engine's active queue because its swarm is dead
/// (no seeders, no peers, no progress). It is paused in the engine — so it can't
/// occupy one of the engine's limited active-download slots — and re-probed
/// periodically; the moment seeders reappear it is released back into the queue.
/// Without this, a handful of dead magnets stuck fetching metadata fill every
/// active slot and head-of-line block every healthy torrent behind them.
model ParkedTorrent {
  hash     String
  engineId String
  name     String
  /// no_seeders | stalled
  reason   String @default("no_seeders")

  parkedAt   DateTime @default(now())
  /// Set while a probe is in flight (the torrent is force-started so it announces
  /// and refreshes its seeder count); cleared when the next tick judges the result.
  probingSince DateTime?
  lastProbedAt DateTime?
  /// Consecutive failed probes — drives the backoff between re-probes.
  probeCount   Int       @default(0)
  /// Tracker-reported seeders as of the last probe.
  lastSeeders  Int       @default(0)
  updatedAt    DateTime  @updatedAt

  engine TorrentEngine @relation(fields: [engineId], references: [id], onDelete: Cascade)

  @@id([engineId, hash])
  @@index([lastProbedAt])
  @@map("parked_torrents")
}

model TorrentCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String?
  savePath  String?
  createdAt DateTime @default(now())

  snapshots TorrentSnapshot[]

  @@map("torrent_categories")
}

model TorrentTag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())

  links TorrentTagLink[]

  @@map("torrent_tags")
}

model TorrentTagLink {
  snapshotId String
  tagId      String
  snapshot   TorrentSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  tag        TorrentTag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([snapshotId, tagId])
  @@map("torrent_tag_links")
}

// ---------------------------------------------------------------------------
// RSS & automation
// ---------------------------------------------------------------------------

model RssFeed {
  id              String   @id @default(uuid())
  name            String
  url             String
  refreshInterval Int      @default(900) // seconds
  isEnabled       Boolean  @default(true)
  lastFetchedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rules   RssRule[]
  history RssHistory[]

  @@map("rss_feeds")
}

model RssRule {
  id            String   @id @default(uuid())
  feedId        String
  name          String
  includeRegex  String?
  excludeRegex  String?
  categoryId    String?
  savePath      String?
  autoDownload  Boolean  @default(true)
  isEnabled     Boolean  @default(true)
  createdAt     DateTime @default(now())

  // TV show airing-status snapshot, captured when the rule was created/edited so
  // the recommendation shown at save time is preserved. Null for non-TV rules.
  mediaType                   String?
  showStatus                  String? // normalized: continuing|returning|planned|on_hiatus|ended|canceled|unknown
  showStatusProvider          String?
  showStatusProviderId        String?
  showStatusCheckedAt         DateTime?
  showStatusRecommendation    String? // recommended|caution|not_recommended|unknown
  showFirstAirDate            DateTime?
  showLastAirDate             DateTime?
  showNextEpisodeAirDate      DateTime?
  showStatusWarnings          Json      @default("[]")
  allowInactiveShowMonitoring Boolean   @default(false)

  feed             RssFeed                  @relation(fields: [feedId], references: [id], onDelete: Cascade)
  matchCandidates  RssRuleMatchCandidate[]
  matchEvaluations RssRuleMatchEvaluation[]
  smartTemplates   RssSmartMatchTemplate[]
  acquisitions     RssAcquisition[]

  @@map("rss_rules")
}

/// Cache of a resolved TV-show airing-status lookup, keyed by provider + the
/// provider's show id. Serves the RSS show-status lookup (avoids re-hitting the
/// provider) and the future background refresh job.
model TvShowStatus {
  id                 String    @id @default(uuid())
  provider           String
  providerShowId     String
  title              String
  normalizedTitle    String
  originalStatus     String?
  normalizedStatus   String // continuing|returning|planned|on_hiatus|ended|canceled|unknown
  recommendation     String // recommended|caution|not_recommended|unknown
  confidence         Float     @default(0)
  firstAirDate       DateTime?
  lastAirDate        DateTime?
  nextEpisodeAirDate DateTime?
  lastEpisodeTitle   String?
  nextEpisodeTitle   String?
  totalSeasons       Int?
  totalEpisodes      Int?
  overview           String?
  posterUrl          String?
  warnings           Json      @default("[]")
  checkedAt          DateTime  @default(now())

  @@unique([provider, providerShowId])
  @@index([normalizedTitle])
  @@map("tv_show_status")
}

// One row per logical release (movie / episode) a rule has grabbed. Turns the
// ranked preference list into a per-title acquisition policy: a rule grabs the
// best-available release for an identity once, upgrades to a strictly
// higher-priority release if one later appears (replacing the old torrent), and
// skips equal-or-lower releases it already satisfied. Without this, each release
// of the same title is an independent download (BluRay + WEBRip both grabbed).
model RssAcquisition {
  id            String   @id @default(uuid())
  rssRuleId     String
  identity      String // logical id, e.g. "movie:michael:2024" | "ep:the show:1:3"
  priorityOrder Int // priority of the candidate currently satisfying it (lower = better)
  releaseTitle  String // the release title currently held
  torrentHash   String? // engine hash of the held torrent, so an upgrade can remove it
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rule RssRule @relation(fields: [rssRuleId], references: [id], onDelete: Cascade)

  @@unique([rssRuleId, identity])
  @@map("rss_acquisitions")
}

model RssSmartMatchTemplate {
  id                  String   @id @default(uuid())
  rssRuleId           String
  sourceName          String
  parsedMetadata      Json
  generatedCandidates Json
  confidenceScore     Int      @default(0)
  userEdited          Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  rule RssRule @relation(fields: [rssRuleId], references: [id], onDelete: Cascade)

  @@index([rssRuleId])
  @@map("rss_smart_match_templates")
}

model RssRuleMatchCandidate {
  id            String    @id @default(uuid())
  rssRuleId     String
  priorityOrder Int       @default(0)
  name          String
  description   String?
  enabled       Boolean   @default(true)
  matchType     String // exact_text | contains_text | regex | wildcard | smart_episode_match | smart_movie_match | fuzzy_match
  pattern       String?
  requiredTerms Json      @default("[]")
  excludedTerms Json      @default("[]")
  qualityRules  Json      @default("{}") // { quality, source, codec, resolution, season, episode, year }
  sizeRules     Json      @default("{}") // { minBytes, maxBytes }
  feedScope     Json      @default("{}") // { feedIds: string[] } — empty = all feeds
  lastMatchedAt DateTime?
  matchCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  rule RssRule @relation(fields: [rssRuleId], references: [id], onDelete: Cascade)

  @@index([rssRuleId])
  @@map("rss_rule_match_candidates")
}

model RssRuleMatchEvaluation {
  id                       String   @id @default(uuid())
  rssRuleId                String
  rssItemId                String
  matchedCandidateId       String?
  matchedCandidatePriority Int?
  result                   String // matched | no_match | skipped_duplicate
  evaluationTrace          Json
  actionTaken              String? // download | none | skipped_duplicate
  torrentHash              String?
  createdAt                DateTime @default(now())

  rule RssRule @relation(fields: [rssRuleId], references: [id], onDelete: Cascade)

  @@index([rssRuleId])
  @@index([rssItemId])
  @@map("rss_rule_match_evaluations")
}

model RssHistory {
  id          String   @id @default(uuid())
  feedId      String
  itemGuid    String
  title       String
  link        String
  magnet      String?  // magnet URI from the feed item, preferred for downloads
  infoHash    String?  // btih extracted from the magnet, lowercased — cross-feed download-dedup key
  matched     Boolean
  downloaded  Boolean
  createdAt   DateTime @default(now())
  feed        RssFeed  @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@unique([feedId, itemGuid])
  @@index([infoHash])
  @@map("rss_history")
}

model AutomationRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  trigger     String   // e.g. torrent.completed
  conditions  Json     // array of {field, op, value}
  actions     Json     // array of {type, params}
  isEnabled   Boolean  @default(true)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs AutomationLog[]

  @@map("automation_rules")
}

model AutomationLog {
  id        String   @id @default(uuid())
  ruleId    String
  status    String   // success | failed | skipped
  context   Json
  message   String?
  createdAt DateTime @default(now())
  rule      AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@map("automation_logs")
}

// ---------------------------------------------------------------------------
// Platform configuration & observability
// ---------------------------------------------------------------------------

model DownloadPath {
  id        String   @id @default(uuid())
  label     String
  path      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("download_paths")
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  level     String   // info | success | warning | error
  title     String
  message   String
  eventType String?
  readAt    DateTime?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  objectType String?
  objectId  String?
  result    String   // success | failure
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemEvent {
  id        String   @id @default(uuid())
  type      String
  severity  String   @default("info")
  payload   Json
  createdAt DateTime @default(now())

  @@index([type])
  @@map("system_events")
}

// ---------------------------------------------------------------------------
// Media renamer
// ---------------------------------------------------------------------------

model MediaLibrary {
  id                  String    @id @default(uuid())
  name                String
  kind                String    @default("tv") // tv | anime | movie | music | audiobook | general
  path                String
  preset              String    @default("plex") // plex | jellyfin | emby | kodi | custom
  template            String?
  mode                String    @default("hardlink") // preview | rename_in_place | rename_move | copy | hardlink | symlink
  isEnabled           Boolean   @default(true)
  scanIntervalMinutes Int?
  lastScanAt          DateTime?
  nfoEnabled          Boolean   @default(false)
  artworkEnabled      Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  items MediaItem[]
  shows MediaShow[]

  @@map("media_libraries")
}

/// A TV show that EXISTS in a library, as one row per show folder on disk.
///
/// The show entity used to be re-derived in memory, three separate times, by
/// climbing `showFolderRoot(path)` from every episode row: once for the media
/// browser (`series-grouping.ts`), once for the watchlist picker
/// (`groupLibraryShows`), and once to choose a download's target folder
/// (`missing-episode-search`). Each derivation could disagree with the others, and
/// the last one had to *reconstruct* a folder name from the show's title when it
/// found no match — which is how `TV Shows/Ghosts 2021 (2021)` and
/// `TV Shows/Happys Place` came to exist beside the real folders.
///
/// `path` is the show's real directory, recorded by the scanner from what is
/// actually on disk. A monitored show points at one of these rows
/// (`MediaAcquisitionWatchlistItem.libraryShowId`), so a grab is filed into a path
/// the library *observed*, never one the acquisition code invented.
model MediaShow {
  id        String  @id @default(uuid())
  libraryId String
  mediaType String  @default("tv") // tv | anime
  title     String
  year      Int?
  /// Absolute path of the show folder, exactly as found on disk.
  path      String
  imdbId    String?
  /// Case/punctuation-insensitive identity key, trailing year stripped
  /// ("Ghosts US (2021)" and "Ghosts (US)" both → "ghosts us"). Equality only —
  /// never a substring test, so "Ghosts US" cannot collide with "Ghosts UK".
  canonicalKey String
  episodeCount Int   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  library        MediaLibrary                    @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  watchlistItems MediaAcquisitionWatchlistItem[]

  @@unique([libraryId, path])
  @@index([imdbId])
  @@index([canonicalKey])
  @@index([libraryId])
  @@map("media_shows")
}

// ---------------------------------------------------------------------------
// Media Manager — a scanned, identified, and enriched view of a library's
// contents. Items are the unit of organisation; each carries its physical
// files, resolved metadata, artwork, subtitles, external ids, and NFO sidecars.
// ---------------------------------------------------------------------------

model MediaItem {
  id               String   @id @default(uuid())
  libraryId        String
  mediaType        String   @default("other_video") // movie | tv | anime | music_video | documentary | other_video
  title            String
  sortTitle        String?
  year             Int?
  season           Int?
  episode          Int?
  /// Last episode covered when ONE file holds several (a two-part premiere shipped as
  /// `S01E01 S01E02` in a single 88-min file). Null for an ordinary single episode.
  /// Without it, every episode the file covers beyond `episode` looks *missing* forever
  /// — the library owns it, the diff disagrees, and the search goes hunting for a
  /// phantom. That is exactly how a wrong-show release gets grabbed.
  episodeEnd       Int?
  matchStatus      String   @default("unmatched") // unmatched | matched | manual
  confidence       Float    @default(0)
  /// Operator-set protection. A locked item is never re-identified, re-enriched,
  /// renamed or moved by ANY automated path — scans, the enrichment pipeline, the
  /// organizer and automation rules all skip it. `matchStatus: 'manual'` only
  /// protects identity; nothing protected a hand-corrected file from the renamer.
  /// This is the valve for a tree UltraTorrent shares with another tool.
  locked           Boolean  @default(false)
  path             String
  duplicateGroupId String?
  seriesImdbId     String?  // parent series tconst for TV episodes; enables missing-episode diff
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  library        MediaLibrary         @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  files          MediaFile[]
  metadata       MediaMetadata?
  artwork        MediaArtwork[]
  subtitles      MediaSubtitle[]
  externalIds    MediaExternalId[]
  nfoFiles       MediaNfoFile[]
  collections    MediaCollectionItem[]
  duplicateGroup MediaDuplicateGroup?  @relation(fields: [duplicateGroupId], references: [id])

  @@index([mediaType])
  @@index([title])
  @@index([year])
  @@index([libraryId])
  @@index([matchStatus])
  @@index([duplicateGroupId])
  @@index([seriesImdbId])
  @@map("media_items")
}

model MediaFile {
  id           String   @id @default(uuid())
  itemId       String
  path         String
  size         BigInt   @default(0)
  container    String?
  videoCodec   String?
  audioCodec   String?
  resolution   String?
  hdr          String?
  language     String?
  releaseGroup String?
  quality      String?

  // --- Measured technical metadata (mediainfo) ------------------------------
  // The fields above are PARSED FROM THE FILENAME, which is why most of them are
  // null in practice: the renamer strips quality tokens, so once a file becomes
  // "Ted Lasso - S02E03 - Do the Right-est Thing.mp4" the codec/resolution are
  // simply gone (measured: 96% of files had no videoCodec, 100% no hdr). These
  // come from reading the container instead, so they are the truth rather than a
  // claim — and they carry the signals a filename never does (real bitrate,
  // exact dimensions, audio channel count).
  width         Int?
  height        Int?
  bitrateKbps   Int?
  durationSec   Int?
  audioChannels Int?
  frameRate     Float?

  /// Where the tech metadata above came from: `filename` (guessed from the name)
  /// or `probe` (measured from the container). Provenance is the point — without
  /// it you cannot tell a trusted value from a guess, nor find what still needs
  /// probing. Null = never touched.
  techSource String?
  probedAt   DateTime?
  /// Why the probe gave up on this file for good. Setting it takes the file OUT of the
  /// backfill's working set permanently — so it is set only for a failure the file itself
  /// causes (unreadable/corrupt), never for a transient one. A timeout on a busy disk is
  /// NOT the file's fault: treating it as one silently dropped two perfectly readable
  /// files on a live NAS.
  probeError String?
  /// Failed attempts so far. A transient failure (timeout, disks busy, file moved
  /// mid-probe) leaves the file in the working set to be retried; this is what stops that
  /// retry being unbounded — after `MAX_PROBE_ATTEMPTS` we give up and set `probeError`.
  probeAttempts Int @default(0)

  createdAt DateTime @default(now())

  item MediaItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  // The backfill's working set: "files never probed, and not already failed".
  @@index([probedAt, probeError])
  @@map("media_files")
}

model MediaMetadata {
  id            String    @id @default(uuid())
  itemId        String    @unique
  title         String?
  originalTitle String?
  sortTitle     String?
  overview      String?   @db.Text
  releaseDate   DateTime?
  year          Int?
  runtime       Int?
  genres        Json      @default("[]")
  studios       Json      @default("[]")
  cast          Json      @default("[]")
  crew          Json      @default("[]")
  directors     Json      @default("[]")
  writers       Json      @default("[]")
  rating        Float?
  certification String?
  tags          Json      @default("[]")
  providerName  String?
  /// field -> the provider that supplied it. Written only by the Universal
  /// scraper, which composes one record from several sources: without it,
  /// `providerName: 'universal'` says nothing about where any given value came
  /// from, and "why does this show say 2014?" is unanswerable.
  fieldSources  Json?
  updatedAt     DateTime  @updatedAt

  item MediaItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("media_metadata")
}

model MediaArtwork {
  id           String   @id @default(uuid())
  itemId       String
  type         String // poster | fanart | logo | clearart | banner | thumbnail | season_poster | episode_thumbnail
  url          String?
  localPath    String?
  source       String?
  selected     Boolean  @default(false)
  width        Int?
  height       Int?
  seasonNumber Int?
  createdAt    DateTime @default(now())

  item MediaItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, type])
  @@map("media_artwork")
}

model MediaSubtitle {
  id        String   @id @default(uuid())
  itemId    String
  path      String
  language  String
  forced    Boolean  @default(false)
  sdh       Boolean  @default(false)
  source    String?
  createdAt DateTime @default(now())

  item MediaItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("media_subtitles")
}

model MediaExternalId {
  id         String  @id @default(uuid())
  itemId     String
  provider   String // tmdb | tvdb | imdb | omdb | anilist
  externalId String
  url        String?

  item MediaItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, provider])
  @@index([provider, externalId])
  @@map("media_external_ids")
}

model MediaCollection {
  id          String   @id @default(uuid())
  name        String
  overview    String?  @db.Text
  artworkPath String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items MediaCollectionItem[]

  @@map("media_collections")
}

model MediaCollectionItem {
  collectionId String
  itemId       String

  collection MediaCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  item       MediaItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([collectionId, itemId])
  @@map("media_collection_items")
}

model MediaRenameTemplate {
  id        String   @id @default(uuid())
  name      String
  mediaType String
  template  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("media_rename_templates")
}

model MediaProcessingJob {
  id         String    @id @default(uuid())
  type       String // library_scan | media_identification | metadata_fetch | artwork_fetch | subtitle_scan | rename_preview | rename_execute | nfo_generate | media_server_refresh
  status     String    @default("queued") // queued | running | completed | failed
  libraryId  String?
  itemId     String?
  payload    Json      @default("{}")
  result     Json?
  error      String?
  progress   Int       @default(0)
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
