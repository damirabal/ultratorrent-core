# ---------------------------------------------------------------------------
# UltraTorrent environment configuration
# Copy to .env and adjust. NEVER commit a real .env.
# ---------------------------------------------------------------------------

# Product
PRODUCT_NAME=UltraTorrent

# Backend
PORT=4000
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173

# Docker: host port the web UI is published on (change if 8080 is already in
# use — common on NAS devices). The backend is not published to the host.
FRONTEND_PORT=8080

# Database (PostgreSQL)
# REQUIRED: set a strong, ALPHANUMERIC password (Compose won't start without it).
# For DOCKER installs this is the only DB value you need — the backend derives
# DATABASE_URL from POSTGRES_USER/PASSWORD/DB automatically.
POSTGRES_USER=ultratorrent
POSTGRES_PASSWORD=
POSTGRES_DB=ultratorrent

# DATABASE_URL: only needed for MANUAL (non-Docker) installs; point at your DB
# (host is usually localhost). Ignored by the Docker stack.
# DATABASE_URL=postgresql://ultratorrent:REPLACE_WITH_PASSWORD@localhost:5432/ultratorrent?schema=public

# Redis (cache / BullMQ)
REDIS_HOST=redis
REDIS_PORT=6379

# Auth secrets — REQUIRED in production; generate each with: openssl rand -base64 48
# The backend REFUSES to boot in production if these are unset, a known default,
# or shorter than 32 chars. JWT_ACCESS_SECRET and ENCRYPTION_KEY must DIFFER.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Encrypts 2FA (TOTP) secrets at rest — REQUIRED, must be different from
# JWT_ACCESS_SECRET. Generate with: openssl rand -base64 48
# Changing it invalidates stored TOTP secrets.
ENCRYPTION_KEY=

# Bootstrap super admin (used by the seed script)
# REQUIRED: set a strong password (only used to create the admin on first seed).
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ultratorrent.local
ADMIN_PASSWORD=

# File manager — comma-separated absolute roots the browser may access
FILE_MANAGER_ROOTS=/downloads

# Media metadata providers
# The IMDb provider needs NO environment variables: it is configured entirely
# from the UI (Media > Settings > IMDb) and works from user-provided IMDb
# datasets and/or an optional licensed IMDb API. UltraTorrent does not scrape
# IMDb web pages. The IMDb API base URL and key are stored in Settings (the key
# is AES-GCM encrypted at rest), never in this file.
# The optional keys below are ONLY fallbacks for cross-provider enrichment
# (TMDB /find and OMDb lookups by IMDb id). They are read only if the matching
# Settings value is unset. Leave blank to configure them in the UI instead.
# TMDB_API_KEY=
# OMDB_API_KEY=

# Frontend (build-time)
VITE_API_URL=http://localhost:4000/api
VITE_WS_URL=http://localhost:4000

# Optional bundled rTorrent engine (see docker-compose)
RTORRENT_SCGI_HOST=rtorrent
RTORRENT_SCGI_PORT=5000

# Run the bundled rtorrent (and thus downloaded files) as this user/group.
# Default 1000 matches the app. If your downloads folder is owned by another
# user (e.g. Plex), set these to that user's id/gid — find them with `id plex`
# — so downloads are written as that user without changing the folder's owner.
# PUID=1000
# PGID=1000

# Enable DHT on the bundled rtorrent (default off — this build can crash on a
# DHT internal_error; trackers + PEX still find peers). Set to on to enable.
# RT_DHT=off
